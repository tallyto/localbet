# LocalBet backend
PORT=8080
LOG_LEVEL=INFO

# Public URL used as JWT issuer. Use your final Dokploy domain.
JWT_ISSUER=https://localbet.seudominio.com
JWT_LIFESPAN=86400
JWT_PRIVATE_KEY_B64=cole-a-chave-privateKey.pem-em-base64-aqui
# Optional: only needed if you do not keep publicKey.pem in the image.
# JWT_PUBLIC_KEY_B64=cole-a-chave-publicKey.pem-em-base64-aqui

# Frontend origin allowed to call the API.
# If frontend and backend use different domains, put the frontend URL here.
CORS_ORIGINS=https://localbet.seudominio.com

# PostgreSQL
# If the database is another Dokploy service, DB_HOST is usually the service name.
DB_HOST=postgres
DB_NAME=localbet
DB_USER=localbet
DB_PASS=troque-esta-senha

# Optional if you create the Postgres service from this same env.
POSTGRES_DB=localbet
POSTGRES_USER=localbet
POSTGRES_PASSWORD=troque-esta-senha
